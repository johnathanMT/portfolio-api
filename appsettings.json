{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_AIVEN_HOST;Port=YOUR_PORT;Database=portfolio_db;User=YOUR_USER;Password=YOUR_PASSWORD;SslMode=Required;"
  },

  "Jwt": {
    "Key": "YOUR_SUPER_SECRET_KEY_AT_LEAST_32_CHARACTERS_LONG_CHANGE_THIS",
    "Issuer": "PortfolioApi",
    "Audience": "PortfolioApiUsers",
    "ExpirationHours": 24
  },

  "Cloudinary": {
    "CloudName": "YOUR_CLOUD_NAME",
    "ApiKey": "YOUR_API_KEY",
    "ApiSecret": "YOUR_API_SECRET"
  },

  "Cors": {
    "AllowedOrigins": [
      "https://johnathanmt.github.io",
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },

  "RateLimit": {
    "GeneralPermitLimit": 100,
    "GeneralWindowSeconds": 60,
    "AuthPermitLimit": 10,
    "AuthWindowSeconds": 900
  }
}
